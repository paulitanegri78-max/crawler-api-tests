{
  "info": {
    "name": "Crawler API Tests",
    "description": "Requests for testing the local crawler API running on localhost:4567.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Crawl",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"keyword\": \"security\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/crawl",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "crawl"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const jsonData = pm.response.json();",
              "pm.test('Response contains id', function () {",
              "    pm.expect(jsonData).to.have.property('id');",
              "});",
              "pm.test('Response contains urls array', function () {",
              "    pm.expect(jsonData.urls).to.be.an('array');",
              "});",
              "if (jsonData.id) { pm.environment.set('crawlId', jsonData.id); }"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Crawl By Id",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/crawl/{{crawlId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "crawl", "{{crawlId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const jsonData = pm.response.json();",
              "pm.test('Response id matches request id', function () {",
              "    pm.expect(jsonData.id).to.eql(pm.environment.get('crawlId'));",
              "});",
              "pm.test('Response contains urls', function () {",
              "    pm.expect(jsonData.urls).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
